{
  "model_name": "18_SqueezeNet",
  "description": "SqueezeNet architecture with 8 Fire Modules (KernelBench Level 3, Model 18)",
  "test_config": {
    "batch_size": 2,
    "image_size": 32,
    "num_classes": 10,
    "input_shape": [2, 3, 32, 32],
    "output_shape": [2, 10]
  },
  "levels": {
    "level_3_model": {
      "squeezenet.py": {
        "description": "Full SqueezeNet model with 8 Fire Modules",
        "input_shape": [2, 3, 32, 32],
        "output_shape": [2, 10],
        "children": [
          "level_2_layer/initial_block.py",
          "level_2_layer/fire_module_1.py",
          "level_2_layer/fire_module_2 (same structure, channels 128->16->64+64=128)",
          "level_2_layer/fire_module_3 (same structure, channels 128->32->128+128=256)",
          "level_0_kernel/max_pool2d.py",
          "level_2_layer/fire_module_4 (same structure, channels 256->32->128+128=256)",
          "level_2_layer/fire_module_5 (same structure, channels 256->48->192+192=384)",
          "level_2_layer/fire_module_6 (same structure, channels 384->48->192+192=384)",
          "level_2_layer/fire_module_7 (same structure, channels 384->64->256+256=512)",
          "level_0_kernel/max_pool2d.py",
          "level_2_layer/fire_module_8 (same structure, channels 512->64->256+256=512)",
          "level_2_layer/classifier_block.py"
        ]
      }
    },
    "level_2_layer": {
      "initial_block.py": {
        "description": "Initial Conv(3,96,7,s=2) + ReLU + MaxPool(3,2,ceil)",
        "input_shape": [2, 3, 32, 32],
        "output_shape": [2, 96, 7, 7],
        "children": [
          "level_1_fusion/conv_relu_pool.py"
        ]
      },
      "fire_module_1.py": {
        "description": "Fire Module: squeeze(96->16) + expand(16->64+64=128)",
        "input_shape": [2, 96, 7, 7],
        "output_shape": [2, 128, 7, 7],
        "children": [
          "level_1_fusion/squeeze_relu.py",
          "level_1_fusion/expand_cat.py"
        ],
        "note": "Representative fire module. Fire modules 2-8 share same structure with different channel counts."
      },
      "classifier_block.py": {
        "description": "Dropout(0.0) + Conv(512,10,1) + ReLU + AdaptiveAvgPool(1,1) + Flatten",
        "input_shape": [2, 512, 2, 2],
        "output_shape": [2, 10],
        "children": [
          "level_0_kernel/dropout.py",
          "level_0_kernel/conv2d_classifier.py",
          "level_0_kernel/relu.py",
          "level_0_kernel/adaptive_avg_pool2d.py",
          "level_0_kernel/flatten.py"
        ]
      }
    },
    "level_1_fusion": {
      "conv_relu_pool.py": {
        "description": "Conv2d(3,96,7,s=2) + ReLU + MaxPool2d(3,2,ceil)",
        "input_shape": [2, 3, 32, 32],
        "output_shape": [2, 96, 7, 7],
        "children": [
          "level_0_kernel/conv2d_3_96.py",
          "level_0_kernel/relu.py",
          "level_0_kernel/max_pool2d.py"
        ]
      },
      "squeeze_relu.py": {
        "description": "Conv2d(96,16,1) + ReLU (squeeze path of Fire Module 1)",
        "input_shape": [2, 96, 7, 7],
        "output_shape": [2, 16, 7, 7],
        "children": [
          "level_0_kernel/conv2d_squeeze.py",
          "level_0_kernel/relu.py"
        ]
      },
      "expand_cat.py": {
        "description": "Parallel [Conv2d(16,64,1)+ReLU, Conv2d(16,64,3,p=1)+ReLU] -> cat",
        "input_shape": [2, 16, 7, 7],
        "output_shape": [2, 128, 7, 7],
        "children": [
          "level_0_kernel/conv2d_expand1x1.py",
          "level_0_kernel/relu.py",
          "level_0_kernel/conv2d_expand3x3.py",
          "level_0_kernel/relu.py",
          "level_0_kernel/cat.py"
        ],
        "topology": "parallel_paths_then_cat"
      }
    },
    "level_0_kernel": {
      "conv2d_3_96.py": {
        "description": "Conv2d(3, 96, kernel_size=7, stride=2)",
        "input_shape": [2, 3, 32, 32],
        "output_shape": [2, 96, 13, 13],
        "op_type": "conv2d"
      },
      "relu.py": {
        "description": "ReLU(inplace=True)",
        "input_shape": [2, "C", "H", "W"],
        "output_shape": [2, "C", "H", "W"],
        "op_type": "activation"
      },
      "max_pool2d.py": {
        "description": "MaxPool2d(kernel_size=3, stride=2, ceil_mode=True)",
        "input_shape": [2, 96, 13, 13],
        "output_shape": [2, 96, 7, 7],
        "op_type": "pooling"
      },
      "conv2d_squeeze.py": {
        "description": "Conv2d(96, 16, kernel_size=1) - squeeze 1x1 conv",
        "input_shape": [2, 96, 7, 7],
        "output_shape": [2, 16, 7, 7],
        "op_type": "conv2d"
      },
      "conv2d_expand1x1.py": {
        "description": "Conv2d(16, 64, kernel_size=1) - expand 1x1 conv",
        "input_shape": [2, 16, 7, 7],
        "output_shape": [2, 64, 7, 7],
        "op_type": "conv2d"
      },
      "conv2d_expand3x3.py": {
        "description": "Conv2d(16, 64, kernel_size=3, padding=1) - expand 3x3 conv",
        "input_shape": [2, 16, 7, 7],
        "output_shape": [2, 64, 7, 7],
        "op_type": "conv2d"
      },
      "cat.py": {
        "description": "torch.cat along dim=1 (channel concatenation)",
        "input_shape": [[2, 64, 7, 7], [2, 64, 7, 7]],
        "output_shape": [2, 128, 7, 7],
        "op_type": "cat"
      },
      "conv2d_classifier.py": {
        "description": "Conv2d(512, 10, kernel_size=1) - classifier conv",
        "input_shape": [2, 512, 2, 2],
        "output_shape": [2, 10, 2, 2],
        "op_type": "conv2d"
      },
      "adaptive_avg_pool2d.py": {
        "description": "AdaptiveAvgPool2d((1,1)) - global average pooling",
        "input_shape": [2, 10, 2, 2],
        "output_shape": [2, 10, 1, 1],
        "op_type": "pooling"
      },
      "dropout.py": {
        "description": "Dropout(p=0.0) - effectively identity",
        "input_shape": [2, 512, 2, 2],
        "output_shape": [2, 512, 2, 2],
        "op_type": "dropout"
      },
      "flatten.py": {
        "description": "torch.flatten(x, 1) - flatten spatial dims",
        "input_shape": [2, 10, 1, 1],
        "output_shape": [2, 10],
        "op_type": "reshape"
      }
    }
  },
  "fire_module_configs": {
    "fire1": {"in_channels": 96,  "squeeze": 16, "expand1x1": 64,  "expand3x3": 64,  "output_channels": 128, "spatial": [7, 7]},
    "fire2": {"in_channels": 128, "squeeze": 16, "expand1x1": 64,  "expand3x3": 64,  "output_channels": 128, "spatial": [7, 7]},
    "fire3": {"in_channels": 128, "squeeze": 32, "expand1x1": 128, "expand3x3": 128, "output_channels": 256, "spatial": [7, 7]},
    "fire4": {"in_channels": 256, "squeeze": 32, "expand1x1": 128, "expand3x3": 128, "output_channels": 256, "spatial": [4, 4]},
    "fire5": {"in_channels": 256, "squeeze": 48, "expand1x1": 192, "expand3x3": 192, "output_channels": 384, "spatial": [4, 4]},
    "fire6": {"in_channels": 384, "squeeze": 48, "expand1x1": 192, "expand3x3": 192, "output_channels": 384, "spatial": [4, 4]},
    "fire7": {"in_channels": 384, "squeeze": 64, "expand1x1": 256, "expand3x3": 256, "output_channels": 512, "spatial": [4, 4]},
    "fire8": {"in_channels": 512, "squeeze": 64, "expand1x1": 256, "expand3x3": 256, "output_channels": 512, "spatial": [2, 2]}
  }
}
